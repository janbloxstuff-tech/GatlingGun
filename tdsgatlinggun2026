-- 5. Core NPC ESP Backend Engine (LAG-FREE HIGH PERFORMANCE CORE V3)
local npcFolder = workspace:WaitForChild("NPCs")
local activeEsp = {}
local cachedTables = {} 

-- High-speed garbage collector scanner running cleanly on independent threads
local function scanGarbageCollectorFor(npc)
    if cachedTables[npc] then return cachedTables[npc] end
    
    local pointer = npc:FindFirstChild("RootPointer")
    if pointer and pointer.Value then
        local gcObjects = getgc(true)
        for i = 1, #gcObjects do
            local v = gcObjects[i]
            if typeof(v) == "table" and v.Model == npc and v.Health then
                cachedTables[npc] = v
                return v
            end
        end
    end
    return nil
end

local function cleanEspOf(npc)
    if activeEsp[npc] then
        for _, object in pairs(activeEsp[npc]) do
            if object then object:Destroy() end
        end
        activeEsp[npc] = nil
    end
    cachedTables[npc] = nil
end

local function applyEsp(npc)
    if not npc:IsA("Model") or npc.Name == "Red" or npc.Name == "Blue" then return end
    
    local primaryPart = npc.PrimaryPart or npc:WaitForChild("Hitbox", 5) or npc:WaitForChild("HumanoidRootPart", 5)
    if not primaryPart then return end

    cleanEspOf(npc)
    activeEsp[npc] = {}

    -- Safe background daemon task loop to cleanly pull initialization data without frame stutter
    local keepScanning = true
    task.spawn(function()
        while keepScanning and npc:IsDescendantOf(workspace) do
            local foundTable = scanGarbageCollectorFor(npc)
            if foundTable then break end
            task.wait(0.5) -- Low-frequency polling interval entirely removes spawn spikes
        end
    end)

    -- Visual Highlight Box
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESPHighlight_" .. npc.Name
    highlight.Adornee = npc
    highlight.FillColor = Color3.fromRGB(255, 65, 65)
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineTransparency = 0
    highlight.Enabled = getgenv().npcesp
    highlight.Parent = ScreenGui
    table.insert(activeEsp[npc], highlight)

    -- Overhead 2D Info Billboard
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESPTag"
    billboard.Adornee = primaryPart
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3.5, 0)
    billboard.AlwaysOnTop = true
    billboard.Enabled = getgenv().npcesp
    billboard.Parent = ScreenGui
    table.insert(activeEsp[npc], billboard)

    local infoLabel = Instance.new("TextLabel")
    infoLabel.Size = UDim2.new(1, 0, 1, 0)
    infoLabel.BackgroundTransparency = 1
    infoLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    infoLabel.TextSize = 13
    infoLabel.Font = Enum.Font.SourceSansBold
    infoLabel.TextStrokeTransparency = 0
    infoLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    infoLabel.Parent = billboard

    -- Dynamic Live Updating Loop (Strictly Read-Only Pointer Processing)
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not npc:IsDescendantOf(workspace) or not getgenv().npcesp then
            keepScanning = false
            cleanEspOf(npc)
            if connection then connection:Disconnect() end
            return
        end
        
        local cleanName = npc.Name:gsub("Enemy", ""):gsub("Unit", "")
        if cleanName == "" or not cleanName then cleanName = "Enemy Target" end
        
        local healthText = "[Loading...]"
        
        -- Instantaneous direct table verification layer
        local dataTable = cachedTables[npc]
        if dataTable and dataTable.Health then
            healthText = string.format("[HP: %d/%d]", math.round(dataTable.Health), math.round(dataTable.MaxHealth))
        elseif npc:FindFirstChild("Humanoid") then
            healthText = string.format("[HP: %d/%d]", math.round(npc.Humanoid.Health), math.round(npc.Humanoid.MaxHealth))
        end
        
        infoLabel.Text = string.format("%s\n%s", cleanName, healthText)
    end)
end

-- Deep scanner function that walks inside subfolders safely
local function processNPCFolder(folder)
    for _, item in pairs(folder:GetChildren()) do
        if item:IsA("Model") then
            if item.Name == "Red" or item.Name == "Blue" then
                processNPCFolder(item)
                item.ChildAdded:Connect(function(child)
                    if child:IsA("Model") then task.spawn(applyEsp, child) end
                end)
            else
                task.spawn(applyEsp, item)
            end
        elseif item:IsA("Folder") then
            processNPCFolder(item)
            item.ChildAdded:Connect(function(child)
                if child:IsA("Model") then task.spawn(applyEsp, child) end
            end)
        end
    end
end

processNPCFolder(npcFolder)

npcFolder.ChildAdded:Connect(function(child)
    if child:IsA("Model") then
        if child.Name == "Red" or child.Name == "Blue" then
            processNPCFolder(child)
            child.ChildAdded:Connect(function(grandchild)
                if grandchild:IsA("Model") then task.spawn(applyEsp, grandchild) end
            end)
        else
            task.spawn(applyEsp, child)
        end
    elseif child:IsA("Folder") then
        processNPCFolder(child)
    end
end)

