-- Utility Component Construction for Toggles
local function createToggleRow(name, labelText, globalVar, layoutOrder)
    local Row = Instance.new("Frame")
    Row.Size = UDim2.new(0, 240, 0, 32)
    Row.BackgroundTransparency = 1
    Row.LayoutOrder = layoutOrder
    
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0, 150, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = labelText
    Label.TextColor3 = Color3.fromRGB(200, 200, 200)
    Label.TextSize = 13
    Label.Font = Enum.Font.SourceSans
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Row
    
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(0, 75, 0, 26)
    Btn.Position = UDim2.new(1, -75, 0.5, -13)
    Btn.BorderSizePixel = 0
    Btn.Font = Enum.Font.SourceSansBold
    Btn.TextSize = 11
    
    local function updateVisuals()
        local state = getgenv()[globalVar]
        Btn.Text = state and "ENABLED" or "DISABLED"
        Btn.BackgroundColor3 = state and Color3.fromRGB(46, 117, 89) or Color3.fromRGB(150, 61, 61)
        Btn.TextColor3 = state and Color3.fromRGB(180, 255, 210) or Color3.fromRGB(255, 210, 210)
    end
    
    Btn.MouseButton1Click:Connect(function()
        getgenv()[globalVar] = not getgenv()[globalVar]
        updateVisuals()
    end)
    
    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 4)
    BtnCorner.Parent = Btn
    
    updateVisuals()
    Btn.Parent = Row
    Row.Parent = MainFrame
end

-- Utility Component Construction for Sliders
local function createSliderRow(name, labelText, globalVar, minVal, maxVal, isDecimal, layoutOrder)
    local Row = Instance.new("Frame")
    Row.Size = UDim2.new(0, 240, 0, 42)
    Row.BackgroundTransparency = 1
    Row.LayoutOrder = layoutOrder
    
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, 0, 0, 18)
    Label.BackgroundTransparency = 1
    Label.Text = labelText .. ": " .. tostring(getgenv()[globalVar])
    Label.TextColor3 = Color3.fromRGB(200, 200, 200)
    Label.TextSize = 12
    Label.Font = Enum.Font.SourceSans
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Row
    
    local SliderTrack = Instance.new("Frame")
    SliderTrack.Size = UDim2.new(1, 0, 0, 6)
    SliderTrack.Position = UDim2.new(0, 0, 0, 24)
    SliderTrack.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    SliderTrack.BorderSizePixel = 0
    SliderTrack.Parent = Row
    
    local TrackCorner = Instance.new("UICorner")
    TrackCorner.CornerRadius = UDim.new(0, 3)
    TrackCorner.Parent = SliderTrack
    
    local SliderFill = Instance.new("Frame")
    SliderFill.BackgroundColor3 = Color3.fromRGB(65, 120, 200)
    SliderFill.BorderSizePixel = 0
    SliderFill.Parent = SliderTrack
    
    local FillCorner = Instance.new("UICorner")
    FillCorner.CornerRadius = UDim.new(0, 3)
    FillCorner.Parent = SliderFill
    
    local SliderBtn = Instance.new("TextButton")
    SliderBtn.Size = UDim2.new(0, 14, 0, 14)
    SliderBtn.Position = UDim2.new(0, -7, 0.5, -7)
    SliderBtn.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
    SliderBtn.Text = ""
    SliderBtn.BorderSizePixel = 0
    SliderBtn.Parent = SliderTrack
    
    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(1, 0)
    BtnCorner.Parent = SliderBtn
    
    local function setSliderValue(percentage)
        percentage = math.clamp(percentage, 0, 1)
        local rawValue = minVal + (percentage * (maxVal - minVal))
        
        if not isDecimal then
            rawValue = math.round(rawValue)
        else
            rawValue = math.round(rawValue * 100) / 100
        end
        
        getgenv()[globalVar] = rawValue
        Label.Text = labelText .. ": " .. tostring(rawValue)
        
        SliderBtn.Position = UDim2.new(percentage, -7, 0.5, -7)
        SliderFill.Size = UDim2.new(percentage, 0, 1, 0)
    end
    
    local initialPercentage = (getgenv()[globalVar] - minVal) / (maxVal - minVal)
    setSliderValue(initialPercentage)
    
    local snapConnection
    SliderBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if snapConnection then snapConnection:Disconnect() end
            
            snapConnection = RunService.RenderStepped:Connect(function()
                local mousePos = UserInputService:GetMouseLocation().X
                local trackStart = SliderTrack.AbsolutePosition.X
                local trackWidth = SliderTrack.AbsoluteSize.X
                local percentage = (mousePos - trackStart) / trackWidth
                setSliderValue(percentage)
            end)
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    if snapConnection then
                        snapConnection:Disconnect()
                        snapConnection = nil
                    end
                end
            end)
        end
    end)
    
    Row.Parent = MainFrame
end

